# 最大文档长度（字符数）
TOOL_MAX_DOC_LENGTH=360

# 最大函数名长度（字符数）
TOOL_MAX_FUNC_NAME_LENGTH=80

# 最大结果输出长度（字符数）
TOOL_MAX_RESULT_LENGTH=30000

# 列表截断阈值（项目数量上限）
TOOL_LIST_TRUNCATE_THRESHOLD=100

# 字典截断阈值（键值对数量上限）
TOOL_DICT_TRUNCATE_THRESHOLD=100

# 是否自动查看 ManualAid 结果（支持 true/false/yes/no/on/off）
MANUALAID_AUTO_VIEW=true

# 结果过期时间（分钟）
RESULT_EXPIRE_MINUTES=5

# 清理任务间隔时间（分钟）
RESULT_CLEANUP_MINUTES=15

# 是否自动复制结果（支持 true/false/yes/no/on/off）
MANUALAID_AUTO_COPY=true

# 会话持续时间持久化间隔（秒）
# 应用会每隔 N 秒将当前会话耗时写入数据库，
SESSION_UPDATE_INTERVAL=30

# 会话删除标志检查间隔（秒）
# 应用每隔 N 秒检查自身 session 的删除标志：
#   - 若标志被错误设为 1，则还原为 0（防止被其他实例误删）
#   - 同时用于控制异步删除的轮询节奏（标记后 10s/20s/30s 三轮询）
SESSION_FLAG_CHECK_INTERVAL=5

