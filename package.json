{
  "name": "manualaid-dev-tools",
  "version": "1.0.0",
  "author": "Suntion",
  "description": "Dev tools and scripts for ManualAid project",
  "homepage": "https://github.com/SunYanbox/ManualAid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SunYanbox/ManualAid.git"
  },
  "bugs": {
    "url": "https://github.com/SunYanbox/ManualAid/issues"
  },
  "scripts": {
    "fw:format:check": "conda activate ManualAid && python ./scripts/fix_fullwidth.py check",
    "md:format:check": "npx markdownlint .",
    "ruff:format:check": "conda activate ManualAid && ruff check .",
    "eslint:format:check": "npx eslint .",
    "prettier:format:check": "npx prettier --check .",
    "fw:format:fix": "conda activate ManualAid && python ./scripts/fix_fullwidth.py write",
    "md:format:fix": "npx markdownlint --fix .",
    "ruff:format:fix": "conda activate ManualAid && ruff format .",
    "prettier:format:fix": "npx prettier --write .",
    "format:check": "npm run fw:format:check && npm run md:format:check && npm run ruff:format:check && npm run eslint:format:check && npm run prettier:format:check",
    "format:fix": "npm run fw:format:fix && npm run md:format:fix && npm run ruff:format:fix && npm run prettier:format:fix",
    "test:ts": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest --passWithNoTests",
    "test:py": "conda activate ManualAid && pytest tests/ -v --cov=src --cov-report=term-missing",
    "test": "npm run test:ts && npm run test:py",
    "before:commit": "npm run format:fix && npm run test && npm run format:check",
    "ci": "npm run before:commit"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "cross-env": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.2"
  }
}
